<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.example.travel_buddy.presentation.auth.SplashFragment"
        android:label="Splash">
        <action
            android:id="@+id/action_splashFragment_to_discoveryFragment"
            app:destination="@id/discoveryFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.travel_buddy.presentation.auth.RegisterFragment"
        android:label="Register">
        <action
            android:id="@+id/action_registerFragment_to_discoveryFragment"
            app:destination="@id/discoveryFragment"
            app:popUpTo="@id/registerFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.travel_buddy.presentation.profile.ProfileFragment"
        android:label="Profile">
        <action
            android:id="@+id/action_profileFragment_to_editProfileFragment"
            app:destination="@id/editProfileFragment" />
        <action
            android:id="@+id/action_profileFragment_to_tripDetailFragment"
            app:destination="@id/tripDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/editProfileFragment"
        android:name="com.example.travel_buddy.presentation.profile.EditProfileFragment"
        android:label="Edit Profile" />

    <fragment
        android:id="@+id/discoveryFragment"
        android:name="com.example.travel_buddy.presentation.discovery.DiscoveryFragment"
        android:label="Discovery">
        <action
            android:id="@+id/action_discoveryFragment_to_createTripFragment"
            app:destination="@id/createTripFragment" />
        <action
            android:id="@+id/action_discoveryFragment_to_tripDetailFragment"
            app:destination="@id/tripDetailFragment" />
        <action
            android:id="@+id/action_discoveryFragment_to_profileFragment"
            app:destination="@id/profileFragment" />
    </fragment>

    <fragment
        android:id="@+id/createTripFragment"
        android:name="com.example.travel_buddy.presentation.post.CreateTripFragment"
        android:label="Create Trip" />

    <fragment
        android:id="@+id/tripDetailFragment"
        android:name="com.example.travel_buddy.presentation.post.TripDetailFragment"
        android:label="Trip Detail">
        <argument
            android:name="postId"
            app:argType="string" />
    </fragment>

</navigation>
